{
  "name": "job-applica",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/frontend",
    "apps/browser-extension",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "yarn workspace frontend dev",
    "dev:extension": "yarn workspace jobapplica--extension dev",
    "dev:website": "npm --prefix apps/website run dev",
    "build:frontend": "yarn workspace frontend build",
    "build:extension": "yarn workspace jobapplica--extension build",
    "build:website": "npm --prefix apps/website run build",
    "generate:website": "npm --prefix apps/website run generate",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "husky": "^9.1.7"
  }
}
