{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "./src/**/*",
    "./src/**/*.vue",
    "./src/**/*.ts",
    "./src/**/*.d.ts",
    "./src/types/ext.d.ts",
    "../../packages/ui/src/**/*.ts",
    "../../packages/ui/src/**/*.vue"
  ],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@job-applica/ui": ["../../packages/ui/src/index.ts"],
      "@job-applica/ui/*": ["../../packages/ui/src/*"]
    }
  }
}
