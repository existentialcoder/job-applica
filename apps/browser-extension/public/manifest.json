{
  "manifest_version": 3,
  "name": "JobApplica Tracker",
  "version": "1.0.5",
  "description": "JobApplica Browser Extension to detect and track jobs from the most popular job portals",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "64": "icon-64.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://app.jobapplica.io/*"
      ],
      "js": [
        "content/webapp.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
